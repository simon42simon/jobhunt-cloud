{
  "name": "jobhunt-cloud",
  "private": true,
  "version": "0.39.1",
  "type": "module",
  "description": "An AI-assisted job-hunt command center: a local-first pipeline (discover -> tailor -> track -> interview) with a pluggable storage seam (files locally, Postgres in the cloud) and a demo mode seeded with fictional data.",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node server/index.js",
    "dev:server:watch": "node --watch server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run dev",
    "migrate": "node ops/migrate.mjs",
    "start:prod": "node ops/migrate.mjs && node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint:activity-log": "node ops/activity-log-lint.mjs",
    "lint:audit-freshness": "node ops/audit-freshness-lint.mjs",
    "lint:closeout": "node ops/closeout-gate-lint.mjs",
    "lint:tokens": "node ops/raw-color-lint.mjs",
    "lint:release-gate": "node ops/release-gate-lint.mjs",
    "lint:audit": "npm audit --omit=dev --audit-level=high",
    "lint:secrets": "gitleaks git . --log-opts=-1 --no-banner --redact",
    "check": "npm run typecheck && npm run test && npm run lint:activity-log && npm run lint:audit-freshness && npm run lint:closeout && npm run lint:tokens && npm run lint:audit && npm run lint:secrets"
  },
  "dependencies": {
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.2",
    "argon2": "^0.44.0",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "dompurify": "^3.4.11",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "gray-matter": "^4.0.3",
    "helmet": "^8.3.0",
    "js-yaml": "^4.3.0",
    "marked": "^14.1.4",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssc-ui": "file:./ssc-ui"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.1.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "embedded-postgres": "^17.10.0-beta.17",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
