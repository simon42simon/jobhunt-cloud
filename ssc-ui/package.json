{
  "name": "ssc-ui",
  "version": "0.1.0",
  "description": "SSC shared design system (shadcn/ui + Tailwind v4) - VENDORED prebuilt dist for the standalone jobhunt-cloud repo. The JS bundle (dist/ssc-ui.js) externalizes only react/react-dom; every other runtime dep is bundled. The `dependencies` below are retained because the shipped type definitions (dist/**/*.d.ts) import their types (e.g. class-variance-authority's VariantProps), so a consumer's typecheck resolves them.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/ssc-ui.js",
  "module": "./dist/ssc-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ssc-ui.js"
    },
    "./styles.css": "./dist/ssc-ui.css"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.462.0",
    "tailwind-merge": "^2.5.5"
  }
}
